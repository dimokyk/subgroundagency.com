PORT=3000

# Google Calendar (calendarios publicos de disponibilidad)
# Deja los dias sin evento para que salgan como Libre.
# Usa eventos de dia completo con titulo "Pendiente" u "Ocupado".
GOOGLE_CALENDAR_API_KEY=
F3LY_CALENDAR_ID=
MEDIOKILO_CALENDAR_ID=

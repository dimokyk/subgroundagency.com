# Opcional: solo si usas `npm run dev` / `npm start` (Express)
PORT=3000

# Google Calendar via enlace secreto ICS (misma logica que la API).
# Sitio estatico: genera datos con `npm run sync:availability` (lee este .env)
# y sube assets/availability-data/bundle.json. En GitHub: secrets + workflow sync-availability.
# Deja los dias sin evento para que salgan como Libre.
# Usa eventos de dia completo con titulo "Pendiente" u "Ocupado".
# En Google Calendar: Integrar calendario -> Direccion secreta en formato iCal.
ESEE_CALENDAR_ICS_URL=
F3LY_CALENDAR_ICS_URL=
MEDIOKILO_CALENDAR_ICS_URL=
